# ─── Contact form delivery ───────────────────────────────────────────────
# Telegram Bot API (create a bot via @BotFather, then get the chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP (Nodemailer) — used as a fallback / archive of contact submissions
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
CONTACT_TO_EMAIL=info@expobrokgroup.com

# Public site URL (used for canonical + OpenGraph + sitemap)
NEXT_PUBLIC_SITE_URL=https://expobrokgroup.com

# ─── Search engine verification ──────────────────────────────────────────
# Google Search Console → Add property → HTML tag → copy the `content` value
GOOGLE_SITE_VERIFICATION=
# Yandex Webmaster → Добавить сайт → Мета-тег → copy the `content` value
YANDEX_VERIFICATION=

# ─── Phase 2 (backend / admin) ───────────────────────────────────────────
DATABASE_URL=
JWT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
